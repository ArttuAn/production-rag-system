{
  "name": "Production RAG",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
  "postCreateCommand": "python -m pip install -r requirements.txt",
  "forwardPorts": [7860],
  "portsAttributes": {
    "7860": {
      "label": "Gradio",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.debugpy"]
    }
  }
}
